#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from reportlab.lib.pagesizes import A4
from reportlab.lib import colors
from reportlab.lib.styles import getSampleStyleSheet, ParagraphStyle
from reportlab.platypus import SimpleDocTemplate, Paragraph, Spacer, Table, TableStyle, PageBreak, Image
from reportlab.lib.units import cm, mm
import sys
import os
import tempfile
import warnings
warnings.filterwarnings('ignore')

# Türkçe karakter desteği için matplotlib fontu (opsiyonel)
plt.rcParams['font.family'] = 'DejaVu Sans'

class VeriAnalizAraci:
    def __init__(self, csv_dosyasi):
        """
        CSV dosyasını yükler ve temel kontrolleri yapar.
        """
        self.dosya_adi = csv_dosyasi
        try:
            self.df = pd.read_csv(csv_dosyasi, encoding='utf-8')
        except UnicodeDecodeError:
            self.df = pd.read_csv(csv_dosyasi, encoding='latin1')
        except Exception as e:
            raise Exception(f"Dosya okunamadı: {e}")
        
        self.numeric_cols = self.df.select_dtypes(include=[np.number]).columns.tolist()
        self.categorical_cols = self.df.select_dtypes(include=['object', 'category']).columns.tolist()
        
        print(f"Veri seti: {self.df.shape[0]} satır, {self.df.shape[1]} sütun")
        print(f"Sayısal sütunlar: {len(self.numeric_cols)} adet")
        
    def eksik_veri_raporu(self):
        """Eksik veri tablosu oluşturur."""
        missing_counts = self.df.isnull().sum()
        missing_percent = (missing_counts / len(self.df)) * 100
        missing_df = pd.DataFrame({
            'Eksik Sayısı': missing_counts,
            'Eksik Yüzdesi (%)': missing_percent
        })
        missing_df = missing_df[missing_df['Eksik Sayısı'] > 0].sort_values('Eksik Yüzdesi (%)', ascending=False)
        return missing_df
    
    def aykiri_deger_raporu(self):
        """
        IQR yöntemiyle aykırı değerleri tespit eder.
        Her sayısal sütun için: aykırı sayısı, alt/üst sınırlar.
        """
        outlier_info = []
        for col in self.numeric_cols:
            data = self.df[col].dropna()
            if len(data) == 0:
                continue
            Q1 = data.quantile(0.25)
            Q3 = data.quantile(0.75)
            IQR = Q3 - Q1
            lower_bound = Q1 - 1.5 * IQR
            upper_bound = Q3 + 1.5 * IQR
            outliers = data[(data < lower_bound) | (data > upper_bound)]
            outlier_info.append({
                'Sütun': col,
                'Aykırı Sayısı': len(outliers),
                'Aykırı Oranı (%)': round(100 * len(outliers) / len(data), 2),
                'Alt Sınır': round(lower_bound, 3),
                'Üst Sınır': round(upper_bound, 3)
            })
        return pd.DataFrame(outlier_info)
    
    def korelasyon_matrisi(self):
        """Sayısal sütunlar arası korelasyon matrisi."""
        if len(self.numeric_cols) < 2:
            return None
        return self.df[self.numeric_cols].corr()
    
    def histogram_figuru(self, output_path):
        """Tüm sayısal sütunlar için histogramlar çizer ve kaydeder."""
        if not self.numeric_cols:
            return None
        n_cols = min(3, len(self.numeric_cols))
        n_rows = (len(self.numeric_cols) + n_cols - 1) // n_cols
        fig, axes = plt.subplots(n_rows, n_cols, figsize=(5*n_cols, 4*n_rows))
        axes = axes.flatten() if n_rows * n_cols > 1 else [axes]
        
        for i, col in enumerate(self.numeric_cols):
            self.df[col].dropna().hist(ax=axes[i], bins=20, edgecolor='black', alpha=0.7)
            axes[i].set_title(col)
            axes[i].set_xlabel('Değer')
            axes[i].set_ylabel('Frekans')
        # Boş alt grafikleri gizle
        for j in range(i+1, len(axes)):
            axes[j].set_visible(False)
        plt.tight_layout()
        plt.savefig(output_path, dpi=150, bbox_inches='tight')
        plt.close()
        return output_path
    
    def boxplot_figuru(self, output_path):
        """Tüm sayısal sütunlar için boxplot çizer."""
        if not self.numeric_cols:
            return None
        fig, ax = plt.subplots(figsize=(max(6, len(self.numeric_cols)*0.8), 6))
        # Veriyi hazırla (eksikleri kaldır)
        data_to_plot = [self.df[col].dropna().values for col in self.numeric_cols]
        bp = ax.boxplot(data_to_plot, labels=self.numeric_cols, vert=True, patch_artist=True)
        ax.set_title('Sayısal Değişkenler için Boxplot (Aykırı Değerler • ile gösterilir)')
        ax.set_ylabel('Değerler')
        plt.xticks(rotation=45, ha='right')
        plt.tight_layout()
        plt.savefig(output_path, dpi=150, bbox_inches='tight')
        plt.close()
        return output_path
    
    def pdf_rapor_olustur(self, output_pdf="veri_analiz_raporu.pdf"):
        """ReportLab kullanarak tüm analiz sonuçlarını bir PDF'de birleştirir."""
        doc = SimpleDocTemplate(output_pdf, pagesize=A4,
                                rightMargin=2*cm, leftMargin=2*cm,
                                topMargin=2*cm, bottomMargin=2*cm)
        styles = getSampleStyleSheet()
        baslik_style = styles['Heading1']
        alt_baslik_style = styles['Heading2']
        normal_style = styles['Normal']
        
        # Özel tablo stili
        table_style = TableStyle([
            ('BACKGROUND', (0, 0), (-1, 0), colors.grey),
            ('TEXTCOLOR', (0, 0), (-1, 0), colors.whitesmoke),
            ('ALIGN', (0, 0), (-1, -1), 'CENTER'),
            ('FONTNAME', (0, 0), (-1, 0), 'Helvetica-Bold'),
            ('FONTSIZE', (0, 0), (-1, 0), 10),
            ('BOTTOMPADDING', (0, 0), (-1, 0), 8),
            ('BACKGROUND', (0, 1), (-1, -1), colors.beige),
            ('GRID', (0, 0), (-1, -1), 0.5, colors.black),
        ])
        
        story = []
        
        # Başlık
        story.append(Paragraph(f"Veri Analiz Raporu: {os.path.basename(self.dosya_adi)}", baslik_style))
        story.append(Spacer(1, 0.5*cm))
        story.append(Paragraph(f"Oluşturulma Tarihi: {pd.Timestamp.now().strftime('%d.%m.%Y %H:%M')}", normal_style))
        story.append(Spacer(1, 0.5*cm))
        
        # Genel bilgiler
        story.append(Paragraph("1. Veri Seti Özeti", alt_baslik_style))
        genel_bilgi = [
            ["Özellik", "Değer"],
            ["Satır Sayısı", str(self.df.shape[0])],
            ["Sütun Sayısı", str(self.df.shape[1])],
            ["Sayısal Sütunlar", str(len(self.numeric_cols))],
            ["Kategorik Sütunlar", str(len(self.categorical_cols))],
        ]
        genel_tablo = Table(genel_bilgi, colWidths=[5*cm, 8*cm])
        genel_tablo.setStyle(table_style)
        story.append(genel_tablo)
        story.append(Spacer(1, 0.5*cm))
        
        # 2. Eksik Veriler
        story.append(Paragraph("2. Eksik Veri Analizi", alt_baslik_style))
        missing_df = self.eksik_veri_raporu()
        if missing_df.empty:
            story.append(Paragraph("Hiç eksik veri bulunmamaktadır.", normal_style))
        else:
            # DataFrame'i list of list'e çevir
            data_missing = [missing_df.columns.tolist()] + missing_df.reset_index().values.tolist()
            # Sütun isimlerini düzelt
            data_missing[0] = ['Sütun Adı', 'Eksik Sayısı', 'Eksik Yüzdesi (%)']
            missing_table = Table(data_missing, colWidths=[5*cm, 3*cm, 3*cm])
            missing_table.setStyle(table_style)
            story.append(missing_table)
        story.append(Spacer(1, 0.5*cm))
        
        # 3. Aykırı Değerler
        story.append(Paragraph("3. Aykırı Değer Analizi (IQR Yöntemi)", alt_baslik_style))
        outlier_df = self.aykiri_deger_raporu()
        if outlier_df.empty:
            story.append(Paragraph("Sayısal sütun bulunamadı veya aykırı değer yok.", normal_style))
        else:
            data_outlier = [outlier_df.columns.tolist()] + outlier_df.values.tolist()
            outlier_table = Table(data_outlier, colWidths=[3*cm, 2.5*cm, 2.5*cm, 2.5*cm, 2.5*cm])
            outlier_table.setStyle(table_style)
            story.append(outlier_table)
        story.append(Spacer(1, 0.5*cm))
        
        # 4. Korelasyon Matrisi
        story.append(Paragraph("4. Korelasyon Matrisi (Sayısal Değişkenler)", alt_baslik_style))
        corr_matrix = self.korelasyon_matrisi()
        if corr_matrix is None or corr_matrix.empty:
            story.append(Paragraph("Korelasyon matrisi oluşturmak için en az 2 sayısal sütun gerekir.", normal_style))
        else:
            # Tablo olarak göster
            corr_rounded = corr_matrix.round(2).fillna('')
            corr_list = [corr_rounded.columns.tolist()] + corr_rounded.values.tolist()
            # Sütun isimlerini ekle (satır başları)
            for i, col_name in enumerate(corr_rounded.columns):
                corr_list[i+1].insert(0, col_name)
            corr_list[0].insert(0, ' ')
            corr_table = Table(corr_list, colWidths=[1.8*cm] * (len(corr_rounded.columns)+1))
            corr_table.setStyle(TableStyle([
                ('BACKGROUND', (0, 0), (-1, 0), colors.grey),
                ('TEXTCOLOR', (0, 0), (-1, 0), colors.whitesmoke),
                ('ALIGN', (0, 0), (-1, -1), 'CENTER'),
                ('FONTNAME', (0, 0), (-1, 0), 'Helvetica-Bold'),
                ('GRID', (0, 0), (-1, -1), 0.5, colors.black),
                ('FONTSIZE', (0, 0), (-1, -1), 8),
            ]))
            story.append(corr_table)
            story.append(Paragraph("Not: Değerler Pearson korelasyon katsayısıdır. 1 = tam pozitif, -1 = tam negatif.", normal_style))
            
            # Heatmap görseli ekle
            fig, ax = plt.subplots(figsize=(8, 6))
            im = ax.imshow(corr_matrix, cmap='coolwarm', vmin=-1, vmax=1, aspect='auto')
            ax.set_xticks(np.arange(len(corr_matrix.columns)))
            ax.set_yticks(np.arange(len(corr_matrix.columns)))
            ax.set_xticklabels(corr_matrix.columns, rotation=45, ha='right')
            ax.set_yticklabels(corr_matrix.columns)
            for i in range(len(corr_matrix.columns)):
                for j in range(len(corr_matrix.columns)):
                    ax.text(j, i, f"{corr_matrix.iloc[i, j]:.2f}", ha='center', va='center', color='black', fontsize=8)
            plt.colorbar(im, ax=ax, label='Korelasyon')
            plt.title('Korelasyon Isı Haritası')
            plt.tight_layout()
            heatmap_path = tempfile.NamedTemporaryFile(suffix='.png', delete=False).name
            plt.savefig(heatmap_path, dpi=120, bbox_inches='tight')
            plt.close()
            story.append(Spacer(1, 0.5*cm))
            story.append(Image(heatmap_path, width=16*cm, height=12*cm))
            os.unlink(heatmap_path)
        story.append(PageBreak())
        
        # 5. Histogramlar
        story.append(Paragraph("5. Histogramlar (Sayısal Değişkenlerin Dağılımı)", alt_baslik_style))
        hist_path = tempfile.NamedTemporaryFile(suffix='.png', delete=False).name
        if self.histogram_figuru(hist_path):
            story.append(Image(hist_path, width=17*cm, height=12*cm))
            os.unlink(hist_path)
        else:
            story.append(Paragraph("Histogram çizilecek sayısal sütun yok.", normal_style))
        story.append(Spacer(1, 0.5*cm))
        
        # 6. Boxplotlar
        story.append(Paragraph("6. Boxplotlar (Aykırı Değer ve Çeyreklik Görünümü)", alt_baslik_style))
        box_path = tempfile.NamedTemporaryFile(suffix='.png', delete=False).name
        if self.boxplot_figuru(box_path):
            story.append(Image(box_path, width=17*cm, height=10*cm))
            os.unlink(box_path)
        else:
            story.append(Paragraph("Boxplot çizilecek sayısal sütun yok.", normal_style))
        
        # Raporu oluştur
        doc.build(story)
        print(f"\n PDF raporu oluşturuldu: {output_pdf}")

def main():
    if len(sys.argv) < 2:
        print("Kullanım: python veri_analiz_araci.py <csv_dosya_yolu> [cikti_pdf_adi]")
        print("Örnek: python veri_analiz_araci.py veriler.csv rapor.pdf")
        sys.exit(1)
    
    csv_dosyasi = sys.argv[1]
    output_pdf = sys.argv[2] if len(sys.argv) > 2 else "veri_analiz_raporu.pdf"
    
    try:
        analiz = VeriAnalizAraci(csv_dosyasi)
        analiz.pdf_rapor_olustur(output_pdf)
        print("\nAnaliz tamamlandı.")
    except Exception as e:
        print(f"Hata: {e}")
        sys.exit(1)

if __name__ == "__main__":
    main()
